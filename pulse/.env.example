# Polymarket API Credentials
# Generate via CLOB API /auth/api-key with wallet signature
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_WALLET_ADDRESS=
POLY_PRIVATE_KEY=

# PULSE Configuration
PULSE_MODE=simulation          # simulation | live
PULSE_STAKE_USD=5              # USD per bet
PULSE_MIN_EDGE=0.08            # Minimum edge to bet (8%)
PULSE_VOLATILITY_WINDOW=300    # Seconds of BTC data for volatility calc
PULSE_STUDENT_T_DF=4           # Student-t degrees of freedom

# Follow Mode (copy-trading)
FOLLOW_WALLETS=                # Comma-separated wallet addresses to follow
FOLLOW_AUTO_MODE=true          # Auto-size bets based on capital fraction
FOLLOW_AUTO_FRACTION=0.001     # 0.1% of capital per bet (auto mode)
FOLLOW_MULTIPLIER=1.0          # Stake multiplier (manual mode: 1.0 = same size as source)
FOLLOW_MAX_STAKE=50            # Max USD per copied bet (safety cap)
