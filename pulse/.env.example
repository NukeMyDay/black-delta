# Polymarket API Credentials
# Generate via CLOB API /auth/api-key with wallet signature
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
POLY_WALLET_ADDRESS=
POLY_PRIVATE_KEY=

# PULSE Configuration
PULSE_MODE=simulation          # simulation | live
PULSE_STAKE_USD=5              # USD per bet
PULSE_MIN_EDGE=0.08            # Minimum edge to bet (8%)
PULSE_VOLATILITY_WINDOW=300    # Seconds of BTC data for volatility calc
PULSE_STUDENT_T_DF=4           # Student-t degrees of freedom
