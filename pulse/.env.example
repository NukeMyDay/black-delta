# ============================================================
#  Polymarket CLOB API Credentials (required for LIVE trading)
# ============================================================
# Step 1: Get a wallet with private key on Polygon (Chain ID 137)
# Step 2: Run: python -c "
#   from py_clob_client.client import ClobClient
#   c = ClobClient('https://clob.polymarket.com', 137, key='YOUR_PRIVATE_KEY')
#   print(c.create_or_derive_api_creds())
# "
# Step 3: Fill in the values below
POLY_PRIVATE_KEY=              # Wallet private key (0x...)
POLY_API_KEY=                  # From create_or_derive_api_creds()
POLY_API_SECRET=               # From create_or_derive_api_creds()
POLY_API_PASSPHRASE=           # From create_or_derive_api_creds()
POLY_FUNDER_ADDRESS=           # Your Polymarket profile address

# ============================================================
#  Follow Mode (copy-trading Bonereaper)
# ============================================================
FOLLOW_SCALE=0.025             # 1/40 of source bets (~200k -> 1k reference)
FOLLOW_MAX_STAKE=50            # Safety cap per trade (USD)

# ============================================================
#  Executor Safety Guards
# ============================================================
EXEC_MAX_BET=50                # Max single bet (USD)
EXEC_DAILY_LOSS_LIMIT=100     # Kill switch triggers at this daily loss (USD)

# ============================================================
#  Signal Module (Bonereaper analysis)
# ============================================================
SIGNAL_WIN_RATE_FULL=0.57      # Win rate for full-Kelly tier (entry < $0.60)
SIGNAL_WIN_RATE_HALF=0.75      # Win rate for half-Kelly tier ($0.60-$0.70)
SIGNAL_KELLY_FRACTION=0.125    # Kelly safety (0.125 = 1/8 Kelly)
SIGNAL_ENTRY_FULL=0.60         # Full tier threshold
SIGNAL_ENTRY_HALF=0.70         # Half tier / skip threshold
SIGNAL_START_CAPITAL=1000.0    # Sim starting capital

# ============================================================
#  PULSE (legacy — currently disabled in dashboard)
# ============================================================
PULSE_STAKE_USD=5
PULSE_MIN_EDGE=0.08
PULSE_VOLATILITY_WINDOW=300
